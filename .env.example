# ======================================================================
# QomraNote configuration
# Copy to .env — docker-compose and the API (godotenv) both read it.
# ======================================================================

# ---- app ----
APP_ENV=development            # development | production
LOG_LEVEL=info                 # debug | info | warn | error

# ---- MongoDB (local, per current setup) ----
MONGO_URI=mongodb://localhost:27017
MONGO_DB=qomranote

# ---- Keycloak ----
# Issuer = the URL embedded in tokens (what the BROWSER uses).
# Internal base = how the API reaches Keycloak (docker service name in compose).
KEYCLOAK_ISSUER=http://localhost:8081/realms/qomranote
KEYCLOAK_INTERNAL_BASE=http://localhost:8081
KEYCLOAK_REALM=qomranote
KEYCLOAK_ADMIN_CLIENT_ID=qomranote-api
KEYCLOAK_ADMIN_CLIENT_SECRET=qomranote-api-secret-change-me

# ---- object storage ----
# Driver "local" stores uploads on disk through the API (works out of the
# box). Flip to "r2" once the Cloudflare R2 credentials below are filled in —
# the presigned direct-to-storage flow activates automatically.
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./data/uploads
PUBLIC_API_BASE=http://localhost:8080

# ---- Cloudflare R2 (S3-compatible) — FILL THESE IN WHEN READY ----
# R2 dashboard → R2 → Manage API Tokens → create an S3 auth token.
R2_ACCOUNT_ID=__FILL_ME__
R2_ACCESS_KEY_ID=__FILL_ME__
R2_SECRET_ACCESS_KEY=__FILL_ME__
R2_BUCKET=qomranote
# Optional: public bucket / custom domain base URL for direct object reads.
# Leave empty to serve objects via 7-day presigned GET URLs instead.
R2_PUBLIC_BASE_URL=

# ---- HTTP ----
HTTP_ADDR=:8080
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
